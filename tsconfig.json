{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "outDir": "./build",
    "rootDir": "./scripts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "rewriteRelativeImportExtensions": true,
    "allowImportingTsExtensions": true
  },
  "include": ["scripts/*.ts"],
  "exclude": ["node_modules"]
}